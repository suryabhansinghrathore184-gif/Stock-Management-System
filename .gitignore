## Ignore Visual Studio temp files, build results, and system files

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bin/
obj/

# Package Manager folders
packages/
node_modules/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# SQL Server database files (if any are local/detached)
*.mdf
*.ldf
*.sdf

# Publish output
Publish/
obj/Release/Package/
